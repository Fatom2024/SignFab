rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthorizedUser() {
      return isSignedIn() && (
        request.auth.token.email == "guaves.consulting@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAuthorized == true)
      );
    }

    match /projects/{projectId} {
      allow read, write: if isAuthorizedUser();
    }

    match /clients/{clientId} {
      allow read, write: if isAuthorizedUser();
    }

    match /productionStepTemplates/{templateId} {
      allow read, write: if isAuthorizedUser();
    }

    match /stock/{itemId} {
      allow read, write: if isAuthorizedUser();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId || (isSignedIn() && request.auth.token.email == "guaves.consulting@gmail.com");
      allow create: if isSignedIn() && request.auth.uid == userId && request.resource.data.isAuthorized == false;
      allow update: if isSignedIn() && request.auth.token.email == "guaves.consulting@gmail.com"; 
    }
  }
}
